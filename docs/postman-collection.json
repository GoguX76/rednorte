  "item": [
    {
      "name": "Auth - Login",
      "request": {
        "method": "POST",
        "url": {
          "raw": "http://localhost:8080/api/auth/users/login",
          "host": ["http://localhost:8080"],
          "path": ["api", "auth", "users", "login"]
        },
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"email\": \"paciente@test.com\",\n  \"password\": \"123456\"\n}"
        }
      },
      "response": [
        {
          "name": "Login exitoso",
          "status": "OK",
          "code": 200,
          "header": [{ "key": "Content-Type", "value": "application/json" }],
          "body": "{\n  \"success\": true,\n  \"data\": {\n    \"token\": \"eyJhbGciOiJIUzI1NiIs...\",\n    \"user\": {\n      \"id\": \"usr_123\",\n      \"first_name\": \"Juan\",\n      \"last_name\": \"Pérez\",\n      \"email\": \"paciente@test.com\",\n      \"role_id\": \"rol_patient\"\n    }\n  }\n}"
        }
      ]
    },
