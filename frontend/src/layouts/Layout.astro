---
import Sidebar from '../components/Sidebar';
import '../styles/globals.css';

export interface Props {
  title?: string;
}

const { title = 'RedNorte — Sistema de Gestión de Lista de Espera Médica' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body>
    <Sidebar client:load />

    <main class="min-h-screen flex flex-col pt-14">
      <slot />

      <footer class="py-6 px-8 text-center text-sm text-slate-400 bg-white border-t border-slate-200 mt-auto">
        RedNorte &copy; {new Date().getFullYear()} &mdash; Sistema de Gestión de Lista de Espera Médica
      </footer>
    </main>
  </body>
</html>
