---
import Header from '../components/Header';
import '../styles/globals.css';

export interface Props {
  title?: string;
}

const { title = 'RedNorte - Sistema de Lista de Espera Médica' } = Astro.props;
---

<!DOCTYPE html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    <Header client:load />
    <main class="flex-1 container mx-auto px-4 py-8">
      <slot />
    </main>
    <footer class="bg-white border-t border-gray-200 py-4 text-center text-sm text-gray-400">
      RedNorte &copy; {new Date().getFullYear()} &mdash; Sistema de Gestión de Lista de Espera Médica
    </footer>
  </body>
</html>
